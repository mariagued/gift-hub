{
    "name": "gift-hub",
    "version": "1.0.0",
    "private": true,
    "description": "Monorepo do projeto da disciplina",
    "engines": {
        "node": ">=20.0.0"
    },
    "workspaces": [
        "apps/*",
        "libs/*"
    ],
    "scripts": {
        "dev:api": "npm run start:dev -w apps/api",
        "dev:web": "npm run start -w apps/web",
        "json-server": "json-server --watch apps/web/db.json --port 3000",
        "lint": "npm run lint --workspaces --if-present",
        "test": "npm run test --workspaces --if-present"
    },
    "keywords": [
        "angular",
        "supabase",
        "monorepo"
    ],
    "author": "Turma de Desenvolvimento Web",
    "license": "UNLICENSED",
    "devDependencies": {
        "daisyui": "^5.5.19",
        "json-server": "^1.0.0-beta.15",
        "supabase": "^2.107.0"
    }
}
